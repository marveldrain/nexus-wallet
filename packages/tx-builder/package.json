{
  "name": "@nexus/tx-builder",
  "version": "0.1.0",
  "description": "Offline multi-chain transaction construction and signing (BTC/EVM/Solana).",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nexus/wallet-core": "file:../wallet-core",
    "@scure/base": "^1.2.1",
    "@scure/btc-signer": "^1.5.0",
    "@solana/web3.js": "^1.98.0",
    "viem": "^2.21.55"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "overrides": {
    "ws": "^8.21.0"
  }
}
