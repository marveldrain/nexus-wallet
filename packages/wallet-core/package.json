{
  "name": "@nexus/wallet-core",
  "version": "0.1.0",
  "description": "Platform-agnostic, non-custodial multi-chain wallet engine (BTC/EVM/Solana).",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "dependencies": {
    "@noble/ciphers": "^1.1.3",
    "@noble/hashes": "^1.6.1",
    "@scure/base": "^1.2.1",
    "@scure/bip32": "^1.6.0",
    "@scure/bip39": "^1.5.0",
    "@scure/btc-signer": "^1.5.0",
    "@solana/web3.js": "^1.98.0",
    "ed25519-hd-key": "^1.3.0",
    "viem": "^2.21.55"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "overrides": {
    "ws": "^8.21.0"
  }
}
