# Nexus wallet app config. Copy to `.env` and override as needed.
# Defaults (in src/config.ts / src/data/networks.ts) are healthy public
# endpoints, so this file is optional for local dev — but see the PRODUCTION
# section below before going live with real user funds (Hard Launch Gate #5).

# Comma-separated RPC endpoints (tried in order, with automatic failover).
VITE_BTC_API_URLS=https://blockstream.info/api,https://mempool.space/api
VITE_ETH_RPC_URLS=https://ethereum-rpc.publicnode.com,https://eth.drpc.org,https://eth-mainnet.public.blastapi.io
VITE_SOL_RPC_URLS=https://solana-rpc.publicnode.com,https://api.mainnet-beta.solana.com
VITE_ETH_CHAIN_ID=1

# One override var per EVM L2 network (same failover pattern).
VITE_POLYGON_RPC_URLS=https://polygon-bor-rpc.publicnode.com
VITE_BSC_RPC_URLS=https://bsc-rpc.publicnode.com
VITE_ARBITRUM_RPC_URLS=https://arbitrum-one-rpc.publicnode.com
VITE_OPTIMISM_RPC_URLS=https://optimism-rpc.publicnode.com
VITE_BASE_RPC_URLS=https://base-rpc.publicnode.com
VITE_AVALANCHE_RPC_URLS=https://avalanche-c-chain-rpc.publicnode.com

# Prices
VITE_COINGECKO_BASE=https://api.coingecko.com/api/v3
# Optional CoinGecko Demo API key for higher rate limits
VITE_COINGECKO_KEY=

# Set to "false" to force offline demo mode (mock balances/prices).
VITE_USE_LIVE=true

# -----------------------------------------------------------------------------
# PRODUCTION (recommended before going live with real funds — see
# docs/PRODUCTION_RPC.md). Free public RPCs are fine for development but are
# not reliable enough for production: no SLA, can rate-limit or go down with
# no notice, and Solana's free endpoints outright block SPL token discovery.
#
# Pattern: put your KEYED url FIRST in each comma-separated list, keep the
# public urls after it as fallback — no code change needed, this is the same
# VITE_*_RPC_URLS mechanism as above. Run `node scripts/verify-rpc-config.mjs`
# after pasting real keys to confirm everything actually connects.
# -----------------------------------------------------------------------------

# --- Option A: Alchemy (https://dashboard.alchemy.com) — one key per network,
# or one multi-chain key depending on your plan. Verified URL pattern:
# https://<subdomain>.g.alchemy.com/v2/<API_KEY>
# VITE_ETH_RPC_URLS=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY,https://ethereum-rpc.publicnode.com
# VITE_SEPOLIA_RPC_URLS=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY,https://ethereum-sepolia-rpc.publicnode.com
# VITE_POLYGON_RPC_URLS=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY,https://polygon-bor-rpc.publicnode.com
# VITE_BSC_RPC_URLS=https://bnb-mainnet.g.alchemy.com/v2/YOUR_KEY,https://bsc-rpc.publicnode.com
# VITE_ARBITRUM_RPC_URLS=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY,https://arbitrum-one-rpc.publicnode.com
# VITE_OPTIMISM_RPC_URLS=https://opt-mainnet.g.alchemy.com/v2/YOUR_KEY,https://optimism-rpc.publicnode.com
# VITE_BASE_RPC_URLS=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY,https://base-rpc.publicnode.com
# VITE_AVALANCHE_RPC_URLS=https://avax-mainnet.g.alchemy.com/v2/YOUR_KEY,https://avalanche-c-chain-rpc.publicnode.com

# --- Option B: Infura (https://www.infura.io) — same idea, different host.
# Verified URL pattern: https://<subdomain>.infura.io/v3/<API_KEY>
# VITE_ETH_RPC_URLS=https://mainnet.infura.io/v3/YOUR_KEY,https://ethereum-rpc.publicnode.com
# VITE_SEPOLIA_RPC_URLS=https://sepolia.infura.io/v3/YOUR_KEY,https://ethereum-sepolia-rpc.publicnode.com
# VITE_POLYGON_RPC_URLS=https://polygon-mainnet.infura.io/v3/YOUR_KEY,https://polygon-bor-rpc.publicnode.com
# VITE_BSC_RPC_URLS=https://bsc-mainnet.infura.io/v3/YOUR_KEY,https://bsc-rpc.publicnode.com
# VITE_ARBITRUM_RPC_URLS=https://arbitrum-mainnet.infura.io/v3/YOUR_KEY,https://arbitrum-one-rpc.publicnode.com
# VITE_OPTIMISM_RPC_URLS=https://optimism-mainnet.infura.io/v3/YOUR_KEY,https://optimism-rpc.publicnode.com
# VITE_BASE_RPC_URLS=https://base-mainnet.infura.io/v3/YOUR_KEY,https://base-rpc.publicnode.com
# VITE_AVALANCHE_RPC_URLS=https://avalanche-mainnet.infura.io/v3/YOUR_KEY,https://avalanche-c-chain-rpc.publicnode.com

# --- Solana: Helius (https://dashboard.helius.dev) is the one we recommend —
# besides being a reliable general-purpose RPC, it's also what UNBLOCKS SPL
# token discovery (free public RPCs reject getTokenAccountsByOwner with a 403).
# Verified URL pattern: https://mainnet.helius-rpc.com/?api-key=<API_KEY>
# VITE_SOL_RPC_URLS=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY,https://solana-rpc.publicnode.com
# VITE_DEVNET_RPC_URLS=https://devnet.helius-rpc.com/?api-key=YOUR_KEY,https://api.devnet.solana.com

# --- Bitcoin has no API-key-in-URL provider like the above (the client speaks
# the Esplora REST API, not Bitcoin Core JSON-RPC). For higher reliability than
# the free tier, Blockstream's Esplora API offers a paid 99.9%-SLA tier and
# mempool.space offers Enterprise sponsorship for higher rate limits — contact
# them directly; once you have a URL, just put it first in VITE_BTC_API_URLS,
# same pattern as everything else here.
